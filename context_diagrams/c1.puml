@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title System Context Diagram for GlobalClass

Person(student, "Student", "A student who attends lectures, asks questions, and participates in Q&A.")
Person(instructor, "Instructor", "An instructor who creates and delivers live lectures.")

System(globalClass, "GlobalClass Platform", "Allows instructors to stream lectures and students to participate in real-time.")
System_Ext(livekit, "LiveKit Cloud", "External WebRTC/HLS media server for high-performance video routing.")

Rel(student, globalClass, "Enrolls in courses, joins live lectures, asks/votes on questions", "HTTPS/WSS")
Rel(instructor, globalClass, "Manages courses, starts/ends live streams, answers questions", "HTTPS/WSS")

Rel_R(globalClass, livekit, "Generates access tokens and manages egress", "HTTPS")

Rel(instructor, livekit, "Publishes WebRTC video stream", "WebRTC")
Rel(student, livekit, "Consumes WebRTC/HLS video stream", "WebRTC/HLS")
@enduml
# ============================================================
# GlobalClass — Root Environment Configuration
# Copy this file to .env and fill in the values.
# ============================================================

# JWT — shared secret between core-api and streaming-engine.
# Both services must use the SAME value or auth will break.
JWT_SECRET=your_jwt_secret_change_in_production

# ── LiveKit SFU (Streaming Engine) ──────────────────────────
# 1. Go to https://cloud.livekit.io and sign up (free tier)
# 2. Click "Create a new project"
# 3. Copy the values from your project's "Keys" page:


LIVEKIT_URL=wss://globalclass-ly5n2c6u.livekit.cloud
LIVEKIT_API_KEY=APIK4wdjWAN29ve
LIVEKIT_API_SECRET=doZr35MAogCCbVsy1I0FsbJzDNoT23qH1zzZiO7OKJB

# ── PostgreSQL & Redis ───────────────────────────────────────
# These are set automatically by docker-compose.yml.
# Only override them if you're running services outside Docker.
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=globalclass
# DB_USER=postgres
# DB_PASSWORD=postgres
# REDIS_HOST=localhost
# REDIS_PORT=6379

PORT=4000

# PostgreSQL — must match docker-compose.yml values
DB_HOST=localhost
DB_PORT=5432
DB_NAME=globalclass
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — MUST be the same value as streaming-engine/.env JWT_SECRET
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=24h
